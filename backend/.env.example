# ─── API Keys ───
SILICONFLOW_API_KEY=sk-oofzqqipefkdxnccrsreklnlxuyvdoycvdwlrqwofcmzetni

# ─── Dense Embedding ───
# Full URL — override for intranet deployment
EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSION=1024

# ─── Reranker ───
RERANKER_URL=https://api.siliconflow.cn/v1/rerank
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B

# ─── Sparse Embedding ───
# Mode: "api" (remote HTTP endpoint) or "local" (FastEmbed model)
SPARSE_EMBEDDING_MODE=api
# API mode — remote endpoint
SPARSE_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
SPARSE_EMBEDDING_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions
# Local mode — FastEmbed (only used when SPARSE_EMBEDDING_MODE=local)
FASTEMBED_CACHE_PATH=./data/fastembed_cache
FASTEMBED_MODEL_NAME=Qdrant/bm42-all-minilm-l6-v2-attentions

# ─── Qdrant ───
QDRANT_STORAGE_PATH=./data/qdrant_storage

# ─── SQLite metadata ───
SQLITE_DATABASE_URL=sqlite+aiosqlite:///./data/metadata.db

# ─── Upload ───
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=100

# ─── Retrieval defaults ───
DEFAULT_TOP_K=20
DEFAULT_TOP_N=3
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ─── Intranet Deployment Example ───
# Uncomment and modify for air-gapped intranet:
#
# EMBEDDING_URL=http://192.168.1.100:8080/v1/embeddings
# RERANKER_URL=http://192.168.1.100:8080/v1/rerank
# SPARSE_EMBEDDING_MODE=api
# SPARSE_EMBEDDING_URL=http://192.168.1.100:8080/v1/sparse-embeddings
