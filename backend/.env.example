# API keys
SILICONFLOW_API_KEY=sk-your-api-key-here

# Dense embedding
EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSION=2560
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CONCURRENCY=5

# Reranker
RERANKER_URL=https://api.siliconflow.cn/v1/rerank
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
RERANKER_CONCURRENCY=5

# Query rewrite / chat completions
QUERY_REWRITE_MODE=dynamic
QUERY_REWRITE_URL=https://api.siliconflow.cn/v1/chat/completions
QUERY_REWRITE_MODEL=Pro/zai-org/GLM-4.7
QUERY_REWRITE_TIMEOUT_MS=15000
QUERY_REWRITE_CONNECT_TIMEOUT_S=5
# QUERY_REWRITE_READ_TIMEOUT_S=15
# QUERY_REWRITE_WRITE_TIMEOUT_S=15
QUERY_REWRITE_POOL_TIMEOUT_S=10
QUERY_REWRITE_CONCURRENCY=10
QUERY_REWRITE_MAX_QUERIES=3
QUERY_REWRITE_CACHE_TTL=300
QUERY_REWRITE_RERANK_POOL_SIZE=40

# Shared HTTP client resilience for embedding / reranker / other shared callers
HTTP_CONNECT_TIMEOUT_S=10
HTTP_READ_TIMEOUT_S=180
HTTP_WRITE_TIMEOUT_S=180
HTTP_POOL_TIMEOUT_S=30

# Sparse embedding
SPARSE_EMBEDDING_MODE=local
SPARSE_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
SPARSE_EMBEDDING_MODEL=Qdrant/bm25
FASTEMBED_CACHE_PATH=./data/fastembed_cache
FASTEMBED_MODEL_NAME=Qdrant/bm25

# BM25
BM25_VOCAB_SIZE=1048576
# BM25_STOPWORDS_PATH=

# Qdrant
QDRANT_STORAGE_PATH=./data/qdrant_storage

# SQLite metadata
SQLITE_DATABASE_URL=sqlite+aiosqlite:///./data/metadata.db

# Uploads
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=100

# Pipeline worker
PIPELINE_MAX_CONCURRENCY=2
PIPELINE_POLL_INTERVAL=2.0
PIPELINE_RETRY_ATTEMPTS=2
PIPELINE_RETRY_BACKOFF_S=5.0

# Retrieval defaults
DEFAULT_TOP_K=20
DEFAULT_TOP_N=3
CONTEXT_SYNTHESIS_WINDOW_SIZE=1
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# Intranet deployment example
# EMBEDDING_URL=http://192.168.1.100:8080/v1/embeddings
# RERANKER_URL=http://192.168.1.100:8080/v1/rerank
# QUERY_REWRITE_URL=http://192.168.1.100:8080/v1/chat/completions
# QUERY_REWRITE_MODEL=Pro/zai-org/GLM-4.7
# SPARSE_EMBEDDING_MODE=api
# SPARSE_EMBEDDING_URL=http://192.168.1.100:8080/v1/sparse-embeddings
